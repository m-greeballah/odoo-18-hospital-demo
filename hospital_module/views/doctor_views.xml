<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Doctor Form View -->
    <record id="view_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Doctor Name"/>
                        </h1>
                        <h3>
                            <field name="ref" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Professional Information">
                            <field name="specialization"/>
                            <field name="degree"/>
                            <field name="experience_years"/>
                            <field name="is_available" widget="boolean_toggle"/>
                        </group>
                        <group string="Contact Information">
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Patients">
                            <field name="patient_ids">
                                <tree>
                                    <field name="ref"/>
                                    <field name="name"/>
                                    <field name="age"/>
                                    <field name="gender"/>
                                    <field name="phone"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Doctor List View -->
    <record id="view_hospital_doctor_tree" model="ir.ui.view">
        <field name="name">hospital.doctor.tree</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <tree string="Doctors">
                <field name="ref"/>
                <field name="name"/>
                <field name="specialization"/>
                <field name="degree"/>
                <field name="experience_years"/>
                <field name="phone"/>
                <field name="patient_count"/>
                <field name="is_available" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Doctor Action -->
    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first doctor!
            </p>
        </field>
    </record>

</odoo>

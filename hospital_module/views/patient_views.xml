<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Patient Form View -->
    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <header>
                    <button name="action_confirm" string="Activate"
                            class="btn-primary" invisible="state == 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,inactive"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Patient Name"/>
                        </h1>
                        <h3>
                            <field name="ref" readonly="1"/>
                        </h3>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="date_of_birth"/>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="blood_group"/>
                        </group>
                        <group string="Contact Information">
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="doctor_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="address" placeholder="Full Address..."/>
                    </group>
                    <notebook>
                        <page string="Appointments">
                            <field name="appointment_ids">
                                <tree>
                                    <field name="ref"/>
                                    <field name="appointment_date"/>
                                    <field name="doctor_id"/>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'done'"
                                           decoration-info="state == 'confirmed'"
                                           decoration-warning="state == 'in_progress'"
                                           decoration-danger="state == 'cancelled'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Patient List View -->
    <record id="view_hospital_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients" decoration-muted="state == 'inactive'">
                <field name="ref"/>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="blood_group"/>
                <field name="phone"/>
                <field name="doctor_id"/>
                <field name="appointment_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-danger="state == 'inactive'"/>
            </tree>
        </field>
    </record>

    <!-- Patient Search View -->
    <record id="view_hospital_patient_search" model="ir.ui.view">
        <field name="name">hospital.patient.search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search string="Search Patients">
                <field name="name"/>
                <field name="ref"/>
                <field name="doctor_id"/>
                <filter string="Active" name="active" domain="[('state','=','active')]"/>
                <filter string="Inactive" name="inactive" domain="[('state','=','inactive')]"/>
                <group expand="0" string="Group By">
                    <filter string="Gender" name="group_gender" context="{'group_by': 'gender'}"/>
                    <filter string="Doctor" name="group_doctor" context="{'group_by': 'doctor_id'}"/>
                    <filter string="Blood Group" name="group_blood" context="{'group_by': 'blood_group'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Patient Action -->
    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hospital_patient_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first patient!
            </p>
        </field>
    </record>

</odoo>
